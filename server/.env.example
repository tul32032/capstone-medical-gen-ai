# Copy this file and fill in values for your environment.
# On Cloud Run, set these as environment variables or via Secret Manager.

SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-service-name-xxxx-region.run.app,your-custom-domain.com

CORS_ALLOWED_ORIGINS=https://your-frontend-url.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-url.com,https://your-service-name-xxxx-region.run.app

# PostgreSQL credentials (Cloud SQL)
DB_NAME=betesbot
DB_USER=betesbot_user
DB_PASSWORD=your-db-password-here
